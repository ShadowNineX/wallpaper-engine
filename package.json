{
  "name": "wallpaper-engine-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "build": "bun run --filter=@wallpaper-engine/devtools build && bun run --filter=wallpaper-engine build",
    "build:devtools": "bun run --filter=@wallpaper-engine/devtools build",
    "build:lib": "bun run --filter=wallpaper-engine build:lib",
    "dev": "bun run --filter=@wallpaper-engine/devtools dev",
    "dev:devtools": "bun run --filter=@wallpaper-engine/devtools dev:ui",
    "dev:demo": "bun run --filter=demo dev",
    "typecheck": "bun run --filter=wallpaper-engine typecheck",
    "test": "bun run --filter=wallpaper-engine test",
    "test:run": "bun run --filter=wallpaper-engine test:run"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
