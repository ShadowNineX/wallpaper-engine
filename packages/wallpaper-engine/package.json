{
  "name": "wallpaper-engine",
  "version": "1.0.0",
  "description": "TypeScript types, Vite plugin, and runtime helpers for Wallpaper Engine web wallpapers",
  "keywords": [
    "wallpaper-engine",
    "wallpaper engine",
    "web wallpaper",
    "vite plugin",
    "typescript"
  ],
  "license": "MIT",
  "author": "ShadowNineX",
  "homepage": "https://github.com/ShadowNineX/wallpaper-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShadowNineX/wallpaper-engine.git"
  },
  "bugs": {
    "url": "https://github.com/ShadowNineX/wallpaper-engine/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js",
      "require": "./dist/helpers.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:lib": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "bun run --cwd ../.. build"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
